{
  "name": "collectibles-exchange",
  "version": "0.1.0",
  "description": "A small NFT collectibles trading platform (cards, art, wine, antiques) — Layer 1: on-chain core.",
  "type": "module",
  "private": true,
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "node": "hardhat node --hostname 0.0.0.0",
    "deploy:local": "hardhat ignition deploy ignition/modules/Deploy.ts --network localhost",
    "seed:local": "hardhat run scripts/seed.ts --network localhost",
    "export:local": "hardhat run scripts/export-abi.ts --network localhost"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox-mocha-ethers": "^3.0.0",
    "@types/chai": "^5.2.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.16.5",
    "chai": "^5.2.1",
    "ethers": "^6.17.0",
    "hardhat": "^3.0.0",
    "mocha": "^11.7.1",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.0"
  }
}
