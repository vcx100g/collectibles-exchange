# Layer 1 (local demo) needs NONE of these — the local chain has built-in funded accounts.
# These are only for Layer 2 when you deploy publicly to Sepolia.

# An Ethereum Sepolia RPC URL (e.g. from Alchemy: https://eth-sepolia.g.alchemy.com/v2/<key>)
SEPOLIA_RPC_URL=

# A DEDICATED throwaway deployer private key holding only Sepolia test ETH.
# NEVER use your real/mainnet key. NEVER commit the real .env.
SEPOLIA_PRIVATE_KEY=

# A single Etherscan API v2 key (works for all chains incl. Sepolia).
ETHERSCAN_API_KEY=
